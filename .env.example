# WAHA Session Configuration
WAHA_SESSION_NAME=default
WAHA_PORT=3000
WAHA_API_URL=http://waha:3000

# Backend Configuration
BACKEND_PORT=8000

# WhatsApp Chat Configuration
# Use the backend/list_chats.py script to find your chat/group ID. Format is typically <number>@c.us or <number>@g.us
TEST_CHAT_ID=your_chat_or_group_id_here@g.us

# Daily Exchange Rate Automation
# Set the time you want the daily message to be sent (24-hour format)
SCHEDULE_TIME=08:00
# Set your timezone to ensure the schedule runs at the correct local time
TZ=America/Bogota
